    try:
    data = input("Введіть продажі через пробіл: ")

    numbers = data.split()
    sales = []

    for n in numbers:
        sales.append(int(n))

    total = sum(sales)

    print("Загальна сума продажів:", total)

except ValueError:
    print("Помилка: неправильне введення")

finally:
    print("Обробку завершено")