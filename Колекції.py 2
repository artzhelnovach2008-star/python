nums = list(map(int, input("Введіть числа через пробіл: ").split()))

total = 0

for n in nums:
    if n > 0:
        total += n

print("Сума додатних чисел:", total)














nums = list(map(int, input("Введіть числа через пробіл: ").split()))

for i in range(len(nums)):
    if nums[i] % 2 == 0:
        print(i, end=" ")









