import random
from rich.console import Console
from rich.panel import Panel
from rich.prompt import Prompt
from rich.table import Table

console = Console()

history = []  # список для истории игр


def show_menu():
    console.print(
        Panel(
            "[bold cyan]МЕНЮ[/bold cyan]\n\n"
            "[1] Почати гру\n"
            "[2] Історія ігор\n"
            "[3] Вихід",
            title="Навігація",
            expand=False
        )
    )


def play_game():
    choices = ["камінь", "ножиці", "папір"]

    user = Prompt.ask("Обери (камінь/ножиці/папір)").lower()

    if user not in choices:
        console.print("[red]Неправильний вибір![/red]")
        return

    bot = random.choice(choices)

    console.print(f"Ти: {user}")
    console.print(f"Комп'ютер: {bot}")

    if user == bot:
        result = "Нічия"
        console.print("[yellow]Нічия![/yellow]")
    elif (user == "камінь" and bot == "ножиці") or \
         (user == "ножиці" and bot == "папір") or \
         (user == "папір" and bot == "камінь"):
        result = "Перемога"
        console.print("[green]Ти переміг![/green]")
    else:
        result = "Поразка"
        console.print("[red]Ти програв![/red]")

    history.append({
        "user": user,
        "bot": bot,
        "result": result
    })


def show_history():
    if not history:
        console.print("[bold]Історія порожня[/bold]")
        return

    table = Table(title="Історія ігор")

    table.add_column("Раунд")
    table.add_column("Гравець")
    table.add_column("Комп'ютер")
    table.add_column("Результат")

    wins = 0
    loses = 0
    draws = 0

    for i, game in enumerate(history, start=1):
        result = game["result"]

        if result == "Перемога":
            colored = "[green]Перемога[/green]"
            wins += 1
        elif result == "Поразка":
            colored = "[red]Поразка[/red]"
            loses += 1
        else:
            colored = "[yellow]Нічия[/yellow]"
            draws += 1

        table.add_row(
            str(i),
            game["user"],
            game["bot"],
            colored
        )

    console.print(table)

    console.print("\n[bold]Статистика:[/bold]")
    console.print(f"[green]Перемог: {wins}[/green]")
    console.print(f"[red]Поразок: {loses}[/red]")
    console.print(f"[yellow]Нічиїх: {draws}[/yellow]")


# -------- Головний цикл --------
while True:
    show_menu()

    choice = Prompt.ask("Обери", choices=["1", "2", "3"])

    if choice == "1":
        play_game()
    elif choice == "2":
        show_history()
    elif choice == "3":
        console.print("До побачення!")
        break