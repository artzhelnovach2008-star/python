text = input("Введи рядок: ")
a = input("Перший символ: ")
b = input("Другий символ: ")

start = text.find(a)
end = text.find(b)

if start != -1 and end != -1 and start < end:
    # удаляем часть строки
    text = text[:start] + text[end+1:]

print(text)












text = input("Введи текст: ")
symbols = input("Введи символи: ")

words = text.split()
result = []

for word in words:
    delete = False
    for s in symbols:
        if s in word:
            delete = True
    if not delete:
        result.append(word)

print(" ".join(result))
















