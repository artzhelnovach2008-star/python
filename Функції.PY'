def show_odd(a, b):
    for i in range(a, b + 1):
        if i % 2 != 0:
            print(i, end=" ")

a = int(input("Введите первое число: "))
b = int(input("Введите второе число: "))

show_odd(a, b)








def draw_line(length, direction, symbol):
    
    if direction == "h":   # горизонтальная
        for i in range(length):
            print(symbol, end="")
    
    elif direction == "v": # вертикальная
        for i in range(length):
            print(symbol)

draw_line(5, "h", "*")
print()
draw_line(5, "v", "*")





