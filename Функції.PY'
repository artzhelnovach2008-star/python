def is_prime(n):

    if n <= 1:
        return False

    for i in range(2, n):
        if n % i == 0:
            return False

    return True


num = int(input("Введите число: "))

if is_prime(num):
    print("Число простое")
else:
    print("Число не простое")






    def is_lucky(n):

    s = str(n)

    if len(s) != 6:
        return False

    first = int(s[0]) + int(s[1]) + int(s[2])
    second = int(s[3]) + int(s[4]) + int(s[5])

    return first == second


num = int(input("Введите шестизначное число: "))

if is_lucky(num):
    print("Число счастливое")
else:
    print("Число не счастливое")